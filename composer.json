{
    "name": "digbang/doctrine-extensions",
    "description": "Doctrine extensions for PostgreSQL",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Guido Contreras Woda",
            "email": "gcontreras@digbang.com"
        },
        {
            "name": "Darío Govergun",
            "email": "dgovergun@digbang.com"
        }
    ],
    "require": {
        "cakephp/chronos": "^2.0",
        "beberlei/doctrineextensions": "^1.2",
        "scienta/doctrine-json-functions": "^6.0",
        "doctrine/orm": "^3.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.0",
        "laravel-doctrine/orm": "^3.2",
        "laravel-doctrine/fluent": "^3.0",
        "illuminate/support": "^10.0 || ^11.0",
        "ramsey/uuid": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Digbang\\DoctrineExtensions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Digbang\\DoctrineExtensions\\": "tests/"
        }
    }
}
